{
  "name": "biblio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=dev vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder --win",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "prepare": "husky"
  },
  "build": {
    "appId": "com.tuusuario.biblio",
    "productName": "biblio",
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "templates/socios.xlsx",
        "to": "templates/socios.xlsx"
      },
      {
        "from": "templates/cuotas.xlsx",
        "to": "templates/cuotas.xlsx"
      },
      {
        "from": "templates/libros.xlsx",
        "to": "templates/libros.xlsx"
      }
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "@formkit/tempo": "^1.1.0",
    "@tailwindcss/vite": "^4.2.4",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "electron-store": "^11.0.2",
    "exceljs": "^4.4.0",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.7",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.7"
  }
}
