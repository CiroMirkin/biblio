{
  "name": "biblio",
  "private": true,
  "version": "0.1.2",
  "type": "commonjs",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=dev vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder --win",
    "dist:win10": "npm run dist",
    "dist:win7": "npm run build && electron-builder --win --ia32",
    "dist:all": "npm run dist",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "prepare": "husky",
    "clean": "tsx clean.ts"
  },
  "build": {
    "publish": [
      {
        "provider": "github",
        "owner": "CiroMirkin",
        "repo": "biblio",
        "releaseType": "release"
      }
    ],
    "appId": "com.tuusuario.biblio",
    "productName": "Biblio",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "ia32"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "artifactName": "Biblio-Setup.exe"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "public/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "templates/socios.xlsx",
        "to": "templates/socios.xlsx"
      },
      {
        "from": "templates/cuotas.xlsx",
        "to": "templates/cuotas.xlsx"
      },
      {
        "from": "templates/libros.xlsx",
        "to": "templates/libros.xlsx"
      }
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "@formkit/tempo": "^1.1.0",
    "@tailwindcss/vite": "^4.2.4",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "electron-log": "^5.4.4",
    "electron-store": "^7.0.3",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/glob": "^8.1.0",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.7",
    "electron": "^22.3.27",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "glob": "^13.0.6",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.7"
  }
}
